{
  "palette": {
    "mode": "dark",
    "primary": {
      "main": "#6B7FF8",
      "light": "#9EAAFB",
      "dark": "#4F63F5",
      "contrastText": "#FFFFFF"
    },
    "secondary": {
      "main": "#8B9FE8",
      "light": "#B4C0F0",
      "dark": "#6478CC",
      "contrastText": "#FFFFFF"
    },
    "background": {
      "default": "#0D0F1A",
      "paper": "#151929",
      "sidebar": "#111424",
      "input": "#1C2035",
      "hover": "#1F2540",
      "elevated": "#1C2035"
    },
    "text": {
      "primary": "#F1F3FF",
      "secondary": "#9BA3C4",
      "disabled": "#5A6180",
      "placeholder": "#5A6180",
      "hint": "#5A6180"
    },
    "divider": "#252B45",
    "border": {
      "default": "#252B45",
      "input": "#2D3454",
      "focus": "#6B7FF8"
    },
    "action": {
      "active": "#6B7FF8",
      "hover": "#1F2540",
      "selected": "#1E2545",
      "disabled": "#5A6180",
      "disabledBackground": "#1C2035",
      "focus": "#1E2545"
    },
    "error": {
      "main": "#F87171",
      "light": "#FCA5A5",
      "dark": "#DC2626",
      "contrastText": "#FFFFFF"
    },
    "warning": {
      "main": "#FBBF24",
      "light": "#FCD34D",
      "dark": "#D97706",
      "contrastText": "#0D0F1A"
    },
    "success": {
      "main": "#34D399",
      "light": "#6EE7B7",
      "dark": "#059669",
      "contrastText": "#0D0F1A"
    },
    "info": {
      "main": "#60A5FA",
      "light": "#93C5FD",
      "dark": "#2563EB",
      "contrastText": "#FFFFFF"
    },
    "marking": {
      "correct": "#34D399",
      "wrong": "#F87171",
      "unattempted": "#9BA3C4"
    },
    "difficulty": {
      "easy": "#34D399",
      "medium": "#FBBF24",
      "difficult": "#F87171"
    },
    "sidebar": {
      "background": "#111424",
      "activeBackground": "#1E2545",
      "activeText": "#6B7FF8",
      "inactiveText": "#9BA3C4",
      "border": "#252B45",
      "logoText": "#F1F3FF"
    },
    "tab": {
      "active": "#6B7FF8",
      "inactive": "#9BA3C4",
      "border": "#252B45",
      "indicator": "#6B7FF8"
    }
  },
  "typography": {
    "fontFamily": "'Inter', 'Roboto', 'Helvetica Neue', Arial, sans-serif",
    "htmlFontSize": 16,
    "fontSize": 14,
    "h1": {
      "fontSize": "2rem",
      "fontWeight": 700,
      "color": "#F1F3FF"
    },
    "h2": {
      "fontSize": "1.5rem",
      "fontWeight": 600,
      "color": "#F1F3FF"
    },
    "h3": {
      "fontSize": "1.25rem",
      "fontWeight": 600,
      "color": "#F1F3FF"
    },
    "h4": {
      "fontSize": "1.125rem",
      "fontWeight": 600,
      "color": "#F1F3FF"
    },
    "h5": {
      "fontSize": "1rem",
      "fontWeight": 600,
      "color": "#F1F3FF"
    },
    "h6": {
      "fontSize": "0.875rem",
      "fontWeight": 600,
      "color": "#F1F3FF"
    },
    "subtitle1": {
      "fontSize": "1rem",
      "fontWeight": 500,
      "color": "#D1D5F0"
    },
    "subtitle2": {
      "fontSize": "0.875rem",
      "fontWeight": 500,
      "color": "#9BA3C4"
    },
    "body1": {
      "fontSize": "0.875rem",
      "fontWeight": 400,
      "color": "#C8CEEA"
    },
    "body2": {
      "fontSize": "0.8125rem",
      "fontWeight": 400,
      "color": "#9BA3C4"
    },
    "button": {
      "fontSize": "0.875rem",
      "fontWeight": 600,
      "textTransform": "none"
    },
    "caption": {
      "fontSize": "0.75rem",
      "fontWeight": 400,
      "color": "#5A6180"
    },
    "overline": {
      "fontSize": "0.75rem",
      "fontWeight": 600,
      "textTransform": "uppercase",
      "letterSpacing": "0.1em"
    },
    "label": {
      "fontSize": "0.875rem",
      "fontWeight": 500,
      "color": "#C8CEEA"
    }
  },
  "shape": {
    "borderRadius": 8,
    "borderRadiusSm": 4,
    "borderRadiusMd": 8,
    "borderRadiusLg": 12,
    "borderRadiusXl": 16,
    "borderRadiusFull": 9999
  },
  "spacing": {
    "unit": 8,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48
  },
  "shadows": {
    "none": "none",
    "xs": "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
    "sm": "0 1px 3px 0 rgba(0, 0, 0, 0.4), 0 1px 2px -1px rgba(0, 0, 0, 0.4)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.35), 0 2px 4px -2px rgba(0, 0, 0, 0.35)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.4)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.45), 0 8px 10px -6px rgba(0, 0, 0, 0.45)",
    "card": "0 1px 3px 0 rgba(0, 0, 0, 0.4)",
    "modal": "0 20px 60px -12px rgba(0, 0, 0, 0.7)"
  },
  "components": {
    "MuiButton": {
      "contained": {
        "background": "#6B7FF8",
        "color": "#FFFFFF",
        "hoverBackground": "#4F63F5",
        "boxShadow": "none",
        "borderRadius": 8,
        "padding": "10px 24px"
      },
      "outlined": {
        "background": "transparent",
        "color": "#6B7FF8",
        "borderColor": "#6B7FF8",
        "hoverBackground": "#1E2545",
        "borderRadius": 8,
        "padding": "9px 24px"
      },
      "text": {
        "color": "#6B7FF8",
        "hoverBackground": "#1E2545"
      }
    },
    "MuiTextField": {
      "background": "#1C2035",
      "borderColor": "#2D3454",
      "borderRadius": 8,
      "focusBorderColor": "#6B7FF8",
      "labelColor": "#C8CEEA",
      "placeholderColor": "#5A6180"
    },
    "MuiSelect": {
      "background": "#1C2035",
      "borderColor": "#2D3454",
      "borderRadius": 8,
      "focusBorderColor": "#6B7FF8",
      "placeholderColor": "#5A6180",
      "arrowColor": "#9BA3C4"
    },
    "MuiCard": {
      "background": "#151929",
      "borderRadius": 12,
      "border": "1px solid #252B45",
      "boxShadow": "0 1px 3px 0 rgba(0, 0, 0, 0.4)"
    },
    "MuiPaper": {
      "background": "#151929",
      "borderRadius": 8,
      "boxShadow": "0 1px 3px 0 rgba(0, 0, 0, 0.4)"
    },
    "MuiRadio": {
      "color": "#2D3454",
      "checkedColor": "#6B7FF8"
    },
    "MuiCheckbox": {
      "color": "#2D3454",
      "checkedColor": "#6B7FF8",
      "borderRadius": 4
    },
    "MuiTabs": {
      "background": "transparent",
      "indicatorColor": "#6B7FF8",
      "activeTextColor": "#6B7FF8",
      "inactiveTextColor": "#9BA3C4",
      "borderBottom": "1px solid #252B45"
    },
    "MuiTab": {
      "activeColor": "#6B7FF8",
      "inactiveColor": "#9BA3C4",
      "fontWeight": 500,
      "fontSize": "0.875rem",
      "padding": "10px 16px"
    },
    "MuiDivider": {
      "color": "#252B45"
    },
    "MuiTooltip": {
      "background": "#252B45",
      "textColor": "#F1F3FF",
      "borderRadius": 6
    },
    "MuiChip": {
      "defaultBackground": "#1C2035",
      "defaultText": "#C8CEEA",
      "primaryBackground": "#1E2545",
      "primaryText": "#6B7FF8",
      "borderRadius": 6
    },
    "MuiDrawer": {
      "background": "#111424",
      "width": 220,
      "borderRight": "1px solid #252B45"
    },
    "MuiAppBar": {
      "background": "#151929",
      "borderBottom": "1px solid #252B45",
      "textColor": "#F1F3FF",
      "boxShadow": "none"
    },
    "MuiBreadcrumbs": {
      "separatorColor": "#5A6180",
      "linkColor": "#9BA3C4",
      "activeColor": "#F1F3FF",
      "fontSize": "0.875rem"
    }
  },
  "layout": {
    "sidebar": {
      "width": 220,
      "collapsedWidth": 64
    },
    "header": {
      "height": 72
    },
    "content": {
      "padding": 32,
      "maxWidth": 1280
    }
  }
}

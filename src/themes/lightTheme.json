{
  "palette": {
    "mode": "light",
    "primary": {
      "main": "#4F63F5",
      "light": "#7B8CF8",
      "dark": "#3347E0",
      "contrastText": "#FFFFFF"
    },
    "secondary": {
      "main": "#1B2458",
      "light": "#3D4D8A",
      "dark": "#0D1430",
      "contrastText": "#FFFFFF"
    },
    "background": {
      "default": "#F7F8FC",
      "paper": "#FFFFFF",
      "sidebar": "#FFFFFF",
      "input": "#FFFFFF",
      "hover": "#F0F2FF"
    },
    "text": {
      "primary": "#111827",
      "secondary": "#6B7280",
      "disabled": "#9CA3AF",
      "placeholder": "#9CA3AF",
      "hint": "#9CA3AF"
    },
    "divider": "#E5E7EB",
    "border": {
      "default": "#E5E7EB",
      "input": "#D1D5DB",
      "focus": "#4F63F5"
    },
    "action": {
      "active": "#4F63F5",
      "hover": "#F0F2FF",
      "selected": "#EEF0FE",
      "disabled": "#9CA3AF",
      "disabledBackground": "#F3F4F6",
      "focus": "#EEF0FE"
    },
    "error": {
      "main": "#EF4444",
      "light": "#FCA5A5",
      "dark": "#B91C1C",
      "contrastText": "#FFFFFF"
    },
    "warning": {
      "main": "#F59E0B",
      "light": "#FCD34D",
      "dark": "#B45309",
      "contrastText": "#FFFFFF"
    },
    "success": {
      "main": "#10B981",
      "light": "#6EE7B7",
      "dark": "#047857",
      "contrastText": "#FFFFFF"
    },
    "info": {
      "main": "#3B82F6",
      "light": "#93C5FD",
      "dark": "#1D4ED8",
      "contrastText": "#FFFFFF"
    },
    "marking": {
      "correct": "#10B981",
      "wrong": "#EF4444",
      "unattempted": "#6B7280"
    },
    "difficulty": {
      "easy": "#10B981",
      "medium": "#F59E0B",
      "difficult": "#EF4444"
    },
    "sidebar": {
      "background": "#FFFFFF",
      "activeBackground": "#EEF0FE",
      "activeText": "#4F63F5",
      "inactiveText": "#6B7280",
      "border": "#E5E7EB",
      "logoText": "#1B2458"
    },
    "tab": {
      "active": "#4F63F5",
      "inactive": "#6B7280",
      "border": "#E5E7EB",
      "indicator": "#4F63F5"
    }
  },
  "typography": {
    "fontFamily": "'Inter', 'Roboto', 'Helvetica Neue', Arial, sans-serif",
    "htmlFontSize": 16,
    "fontSize": 14,
    "h1": {
      "fontSize": "2rem",
      "fontWeight": 700,
      "color": "#111827"
    },
    "h2": {
      "fontSize": "1.5rem",
      "fontWeight": 600,
      "color": "#111827"
    },
    "h3": {
      "fontSize": "1.25rem",
      "fontWeight": 600,
      "color": "#111827"
    },
    "h4": {
      "fontSize": "1.125rem",
      "fontWeight": 600,
      "color": "#111827"
    },
    "h5": {
      "fontSize": "1rem",
      "fontWeight": 600,
      "color": "#111827"
    },
    "h6": {
      "fontSize": "0.875rem",
      "fontWeight": 600,
      "color": "#111827"
    },
    "subtitle1": {
      "fontSize": "1rem",
      "fontWeight": 500,
      "color": "#374151"
    },
    "subtitle2": {
      "fontSize": "0.875rem",
      "fontWeight": 500,
      "color": "#6B7280"
    },
    "body1": {
      "fontSize": "0.875rem",
      "fontWeight": 400,
      "color": "#374151"
    },
    "body2": {
      "fontSize": "0.8125rem",
      "fontWeight": 400,
      "color": "#6B7280"
    },
    "button": {
      "fontSize": "0.875rem",
      "fontWeight": 600,
      "textTransform": "none"
    },
    "caption": {
      "fontSize": "0.75rem",
      "fontWeight": 400,
      "color": "#9CA3AF"
    },
    "overline": {
      "fontSize": "0.75rem",
      "fontWeight": 600,
      "textTransform": "uppercase",
      "letterSpacing": "0.1em"
    },
    "label": {
      "fontSize": "0.875rem",
      "fontWeight": 500,
      "color": "#374151"
    }
  },
  "shape": {
    "borderRadius": 8,
    "borderRadiusSm": 4,
    "borderRadiusMd": 8,
    "borderRadiusLg": 12,
    "borderRadiusXl": 16,
    "borderRadiusFull": 9999
  },
  "spacing": {
    "unit": 8,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48
  },
  "shadows": {
    "none": "none",
    "xs": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "sm": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.07)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.08)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.08)",
    "card": "0 1px 3px 0 rgba(0, 0, 0, 0.08)",
    "modal": "0 20px 60px -12px rgba(0, 0, 0, 0.15)"
  },
  "components": {
    "MuiButton": {
      "contained": {
        "background": "#4F63F5",
        "color": "#FFFFFF",
        "hoverBackground": "#3347E0",
        "boxShadow": "none",
        "borderRadius": 8,
        "padding": "10px 24px"
      },
      "outlined": {
        "background": "transparent",
        "color": "#4F63F5",
        "borderColor": "#4F63F5",
        "hoverBackground": "#EEF0FE",
        "borderRadius": 8,
        "padding": "9px 24px"
      },
      "text": {
        "color": "#4F63F5",
        "hoverBackground": "#EEF0FE"
      }
    },
    "MuiTextField": {
      "background": "#FFFFFF",
      "borderColor": "#D1D5DB",
      "borderRadius": 8,
      "focusBorderColor": "#4F63F5",
      "labelColor": "#374151",
      "placeholderColor": "#9CA3AF"
    },
    "MuiSelect": {
      "background": "#FFFFFF",
      "borderColor": "#D1D5DB",
      "borderRadius": 8,
      "focusBorderColor": "#4F63F5",
      "placeholderColor": "#9CA3AF",
      "arrowColor": "#6B7280"
    },
    "MuiCard": {
      "background": "#FFFFFF",
      "borderRadius": 12,
      "border": "1px solid #E5E7EB",
      "boxShadow": "0 1px 3px 0 rgba(0, 0, 0, 0.08)"
    },
    "MuiPaper": {
      "background": "#FFFFFF",
      "borderRadius": 8,
      "boxShadow": "0 1px 3px 0 rgba(0, 0, 0, 0.08)"
    },
    "MuiRadio": {
      "color": "#D1D5DB",
      "checkedColor": "#4F63F5"
    },
    "MuiCheckbox": {
      "color": "#D1D5DB",
      "checkedColor": "#4F63F5",
      "borderRadius": 4
    },
    "MuiTabs": {
      "background": "transparent",
      "indicatorColor": "#4F63F5",
      "activeTextColor": "#4F63F5",
      "inactiveTextColor": "#6B7280",
      "borderBottom": "1px solid #E5E7EB"
    },
    "MuiTab": {
      "activeColor": "#4F63F5",
      "inactiveColor": "#6B7280",
      "fontWeight": 500,
      "fontSize": "0.875rem",
      "padding": "10px 16px"
    },
    "MuiDivider": {
      "color": "#E5E7EB"
    },
    "MuiTooltip": {
      "background": "#1B2458",
      "textColor": "#FFFFFF",
      "borderRadius": 6
    },
    "MuiChip": {
      "defaultBackground": "#F3F4F6",
      "defaultText": "#374151",
      "primaryBackground": "#EEF0FE",
      "primaryText": "#4F63F5",
      "borderRadius": 6
    },
    "MuiDrawer": {
      "background": "#FFFFFF",
      "width": 220,
      "borderRight": "1px solid #E5E7EB"
    },
    "MuiAppBar": {
      "background": "#FFFFFF",
      "borderBottom": "1px solid #E5E7EB",
      "textColor": "#111827",
      "boxShadow": "none"
    },
    "MuiBreadcrumbs": {
      "separatorColor": "#9CA3AF",
      "linkColor": "#6B7280",
      "activeColor": "#111827",
      "fontSize": "0.875rem"
    }
  },
  "layout": {
    "sidebar": {
      "width": 220,
      "collapsedWidth": 64
    },
    "header": {
      "height": 72
    },
    "content": {
      "padding": 32,
      "maxWidth": 1280
    }
  }
}
